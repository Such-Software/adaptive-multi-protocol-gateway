{
  "default_tier": "interactive-lite",
  "deny_routes": [
    "/admin/*",
    "/api/internal/*",
    "/webhooks/*"
  ],
  "routes": [
    {
      "match": "/play/*"
    },
    {
      "identity": "http-session",
      "match": "/checkout/*",
      "payments": "server-invoice",
      "tier": "transactional"
    },
    {
      "identity": "http-session",
      "match": "/live/*",
      "realtime": true,
      "tier": "realtime"
    },
    {
      "match": "/admin/*",
      "public_allowed": false,
      "tier": "internal"
    }
  ],
  "schema": "ampg.route-manifest.v1"
}
